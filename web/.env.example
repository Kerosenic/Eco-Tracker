# Copy this file to .env.local and fill in real values from Supabase dashboard.
# Never commit .env.local — it's gitignored on purpose.

# Found in Supabase dashboard → Project Settings → API → Project URL
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Found in Supabase dashboard → Project Settings → API → Project API keys → publishable
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Found in Supabase dashboard → Project Settings → API → Project API keys → secret
# DO NOT share this. Rotate it in the dashboard if it ever leaks.
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
